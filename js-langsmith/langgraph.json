{
  "$schema": "https://langgra.ph/schema.json",
  "node_version": "22",
  "image_distro": "wolfi",
  "dependencies": [
    "."
  ],
  "graphs": {
    "agent": "./agent/index.ts:agent"
  },
  "env": ".env",
  "http": {
    "cors": {
      "allow_origins": [
        "*"
      ],
      "allow_methods": [
        "GET",
        "POST",
        "DELETE",
        "OPTIONS"
      ],
      "allow_headers": [
        "Authorization",
        "Content-Type",
        "X-Api-Key"
      ]
    }
  }
}